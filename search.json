---
layout: null
---
[
  {% for post in site.posts %}
    {
      "title"    : "{{ post.title | strip_html | strip_newlines | jsonify }}",
      "category" : "{{ post.category }}",
      "tags"     : "{{ post.tags | join: ', ' }}",
      "url"      : "{{ site.baseurl }}{{ post.url }}",
      "date"     : "{{ post.date | date: '%Y-%m-%d' }}"
    } {% unless forloop.last %},{% endunless %}
  {% endfor %}
]
